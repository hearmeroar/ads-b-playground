# Copy this file to .env and fill in your credentials from the OpenSky
# Network account page (https://opensky-network.org/my-opensky/account) —
# API Client section. Without these variables the backend runs anonymously.
OPENSKY_CLIENT_ID=asplay-api-client
OPENSKY_CLIENT_SECRET=

# Optional: Planespotters requires a descriptive User-Agent with contact info
# (see https://www.planespotters.net/photo/api). The default in app.py works
# out of the box, but you can override it here with your own contact URL/email.
PLANESPOTTERS_USER_AGENT=ADS-B-Playground/1.0 (+https://github.com/adsb-playground)
